generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tournament {
  id     String   @id @default(cuid())
  name   String
  sport  String
  players Player[]
  bracketResults BracketResult[]
}

model Player {
  id             String   @id @default(cuid())
  name           String
  gender         String   // "Boys" or "Girls"
  ageCategory    String   // "U-14", "U-19", or "Open"
  weightClass    String?
  belt           String?
  tournamentId   String
  tournament     Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
}

model BracketResult {
  id           String   @id @default(cuid())
  tournamentId String
  groupKey     String
  winners      Json     // Store winners as JSON
  isFinalized  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
}
